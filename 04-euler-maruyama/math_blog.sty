\ProvidesPackage{mystyle}   % Provide the name of the package

% Required packages
\usepackage{amsmath, amssymb, amsfonts} % For math symbols and fonts
\usepackage{graphicx}                   % For including images
\usepackage{geometry}                   % For page layout and margins
\usepackage{hyperref}                   % For hyperlinks
\usepackage{indentfirst}                % Indent the first paragraph of each section
\usepackage{enumitem}                   % For list customization
\usepackage{xcolor}                     % For colors
\usepackage{wrapfig}                    % For wrapped figures
\usepackage{listings}                   % For code blocks
\usepackage{xcolor}                     % For code syntax highlighting
\usepackage{amsmath, amssymb, amsthm}     % For theorem and proof environments

\usepackage{fancyhdr}
\pagestyle{fancy}
\fancyhf{} 

% 自动获取作者与标题（需在主文件设置 \title 和 \author）
\makeatletter
\newcommand{\gettitle}{\@title}
\newcommand{\getauthor}{\@author}
\makeatother

% 设置页眉和页脚内容
\fancyhead[L]{\small\textit{\Author}}   % 左上角：作者
\fancyhead[C]{\small\textit{\Title}}    % 中上方：标题
% \fancyhead[R]{\small\textit{\leftmark}}    % 右上角：当前章节标题

\fancyfoot[R]{\small\thepage}              % 右下角：页码

% 页眉线，页脚线
\renewcommand{\headrulewidth}{0.4pt}
\renewcommand{\footrulewidth}{0pt} % 页脚不加横线（如需可调回）

% section 进入 \leftmark（适用于 article 类）
\renewcommand{\sectionmark}[1]{\markboth{#1}{}}

% Listings configuration
\lstset{
  language=Haskell,              % Specify the language
  basicstyle=\ttfamily\small,    % Set the font to typewriter and small size
  keywordstyle=\color{blue},     % Color for keywords
  commentstyle=\color{green},    % Color for comments
  stringstyle=\color{red},       % Color for strings
  breaklines=true,               % Enable line wrapping
  breakatwhitespace=true,        % Break lines at whitespace
  numbers=left,                  % Line numbers on the left
  numberstyle=\tiny\color{gray}, % Style for line numbers
  stepnumber=1,                  % Number every line
  numbersep=5pt,                 % Distance between numbers and code
  frame=single,                  % Frame around the code
  backgroundcolor=\color{white}, % Background color
  showspaces=false,              % Don't show spaces
  showstringspaces=false,        % Don't show string spaces
  showtabs=false,                % Don't show tabs
  tabsize=4,                     % Set tab size to 4 spaces
  aboveskip=15pt,                % Space above the code block
  belowskip=10pt                 % Space below the code block
}

% Geometry settings
\geometry{a4paper, margin=1.2in}

% Paragraph settings
\setlength{\parskip}{1em}       % Set paragraph skip

% Theorem and proof environment settings
\theoremstyle{plain}
\newtheorem{theorem}{Theorem}[section]
\newtheorem{lemma}[theorem]{Lemma}
\newtheorem{corollary}[theorem]{Corollary}

\theoremstyle{definition}
\newtheorem{definition}[theorem]{Definition}
\newtheorem{example}[theorem]{Example}

\theoremstyle{remark}
\newtheorem*{remark}{Remark}
\newtheorem*{notation}{Notation}

\theoremstyle{plain}
\newtheorem{proposition}[theorem]{Proposition}
\newtheorem{conjecture}[theorem]{Conjecture}

\newenvironment{proof}[1][Proof]{\noindent \textbf{#1.} }{\qed}

% Proof environment
\renewcommand{\qedsymbol}{$\blacksquare$} % Black square at the end of proofs
